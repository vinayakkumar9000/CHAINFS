# ─── ChainFS Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Never commit .env or any file containing real private keys to version control.

# JSON-RPC endpoint (default: local Hardhat node)
CHAINFS_RPC_URL=http://127.0.0.1:8545

# Deployed ChainFS contract address (required)
CHAINFS_CONTRACT=0x<deployed contract address>

# Signer private key (required for upload; omit for read-only operations)
CHAINFS_PRIVATE_KEY=0x<64-hex-char private key>

# SQLite blob-store path used by Node.js upload/download pipeline
# Default: ~/.chainfs/chainfs.db
CHAINFS_DB_PATH=~/.chainfs/chainfs.db

# SQLite index DB path used by sync-engine, list, and sync commands
# Default: ./data/chainfs.db
CHAINFS_INDEX_DB_PATH=./data/chainfs.db
